hostname KOZPONT_R

ip access-list extended GUEST-ISOLATE
    deny ip 10.1.200.0 0.0.0.255 10.1.0.0 0.0.255.255
    permit ip 10.1.200.0 0.0.0.255 any
ip access-list extended ADMIN-PROTECT
    permit ip 10.1.10.0 0.0.0.255 10.1.150.0 0.0.0.255
    deny ip any 10.1.150.0 0.0.0.255 
    permit ip any any
ip access-list standard NAT-LAN
    permit 10.1.0.0 0.0.255.255

int fa0/1
description Belso_halozat_fele
    ip helper-address 10.1.10.5
    no sh
int fa0/1.999
    encapsulation dot1q 999 native
int fa0/1.20
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 20
    ip address 10.1.20.1 255.255.255.0
    standby 20 ip 10.1.20.3
    standby 20 priority 100
    standby 20 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.30
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 30
    ip address 10.1.30.1 255.255.255.0
    standby 30 ip 10.1.30.3
    standby 30 priority 100
    standby 30 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.40
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 40
    ip address 10.1.40.1 255.255.255.0
    standby 40 ip 10.1.40.3
    standby 40 priority 100
    standby 40 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.50
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 50
    ip address 10.1.50.1 255.255.255.0
    standby 50 ip 10.1.50.3
    standby 50 priority 100
    standby 50 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.60
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 60
    ip address 10.1.60.1 255.255.255.0
    standby 60 ip 10.1.60.3
    standby 60 priority 100
    standby 60 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.70
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 70
    ip address 10.1.70.1 255.255.255.0
    standby 70 ip 10.1.70.3
    standby 70 priority 110
    standby 70 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.80
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 80
    ip address 10.1.80.1 255.255.255.0
    standby 80 ip 10.1.80.3
    standby 80 priority 110
    standby 80 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.10
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 10
    ip address 10.1.10.1 255.255.255.0
    standby 10 ip 10.1.10.3
    standby 10 priority 110
    standby 10 preempt
    ip access-group ADMIN-PROTECT in
int fa0/1.200
    ip nat inside
    ip helper-address 10.1.10.5
    encapsulation dot1q 200
    ip address 10.1.200.1 255.255.255.0
    standby 200 ip 10.1.200.3
    standby 200 priority 110
    standby 200 preempt
    ip access-group GUEST-ISOLATE in
int fa0/1.150
    ip helper-address 10.1.10.5
    encapsulation dot1q 150
    ip address 10.1.150.1 255.255.255.0
    standby 150 ip 10.1.150.3
    standby 150 priority 110
    standby 150 preempt
    ip access-group ADMIN-PROTECT in

int fa0/0
description WAN_fele
    no sh
    ip add 102.54.183.1 255.255.255.252
    ip nat outside
    ip access-group WAN-inbound in

!DINAMIC
ip access-list standard NAT_RULE
    deny 10.1.150.0 255.255.255.0
    deny 10.1.10.5
    deny 10.1.10.6
    permit 10.1.0.0 0.0.255.255
    permit 10.2.0.0 0.0.255.255
ip nat pool NAT_POOL 204.231.55.2 204.231.55.14 netmask 255.255.255.240
ip nat inside source list NAT_RULE pool NAT_POOL overload

!STATIC
ip nat inside source static 10.1.10.5 204.231.55.1
ip nat inside source static 10.1.10.6 204.231.55.17

interface Tunnel1
    ip address 192.168.100.1 255.255.255.252
    tunnel source fa0/0
    tunnel destination 203.0.113.41
    tunnel mode gre ip

ip route 0.0.0.0 0.0.0.0 102.54.183.2
ip route 10.2.0.0 255.255.0.0 192.168.100.2

no ip domain-lookup
login block-for 120 attempts 3 within 60
service password-encryption
username admin privilege 15 secret 1234
username user privilege 1 secret 1234
line console 0
login local
exit
line vty 0 4
login local
exit
ntp authenticate
ntp authentication-key 1 md5 jelszo
ntp trusted-key 1
ntp server 10.1.10.5
clock timezone CET 1
clock timezone CEST 0
do write

snmp-server community PUBLIC RO
snmp-server host 10.1.10.7 version 2c PUBLIC
snmp-server location KOZPONT